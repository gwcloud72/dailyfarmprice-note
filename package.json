{
  "name": "farm-price-note",
  "version": "0.1.0",
  "private": true,
  "description": "React AJAX, GitHub Actions, Gemini AI 리포트를 활용한 농산물 가격 추이 프로젝트",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "update:data": "node scripts/update-crop-prices.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "update:ai-report": "node scripts/generate-ai-reports.mjs",
    "generate:ai-report": "node scripts/generate-ai-reports.mjs",
    "build:with-ai": "npm run update:data && npm run generate:ai-report && npm run validate:data && npm run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.10"
  }
}
