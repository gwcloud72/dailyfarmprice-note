{
  "name": "farm-price-note",
  "version": "0.1.0",
  "private": true,
  "description": "React AJAX, GitHub Actions, Gemini AI 리포트를 활용한 농산물 가격 추이 프로젝트",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "update:data": "node scripts/update-crop-prices.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "update:ai-report": "node scripts/generate-ai-reports.mjs",
    "generate:ai-report": "node scripts/generate-ai-reports.mjs",
    "build:with-ai": "npm run update:data && npm run generate:ai-report && npm run validate:data && npm run build",
    "quality:check": "node scripts/quality-check.mjs",
    "data:check": "node scripts/data-contract-check.mjs",
    "qa:check": "npm run quality:check && npm run data:check && npm run interaction:check && npm run render:check",
    "interaction:check": "node scripts/interaction-check.mjs",
    "render:check": "node scripts/render-check.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.21"
  }
}
